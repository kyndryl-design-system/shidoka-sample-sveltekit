{
	"name": "shidoka-sample-sveltekit",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --open",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.49.0",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^3.0.3",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.3.3",
		"sass": "^1.69.4",
		"svelte": "^5.56.4",
		"svelte-check": "^3.4.3",
		"typescript": "^5.0.0",
		"vite": "^8.1.3"
	},
	"type": "module",
	"dependencies": {
		"@kyndryl-design-system/shidoka-applications": "^2.109.6",
		"@kyndryl-design-system/shidoka-charts": "^2.10.2",
		"@kyndryl-design-system/shidoka-foundation": "^2.8.17",
		"@kyndryl-design-system/shidoka-icons": "^2.26.2"
	},
	"overrides": {
		"cookie": "^0.7.0"
	}
}
